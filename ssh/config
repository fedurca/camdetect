# SSH client config for this workspace.
# Uses the host machine's SSH agent (forwarded into the cloud environment).

Host *
  AddKeysToAgent yes
  IdentitiesOnly yes
  StrictHostKeyChecking accept-new
  IdentityFile ~/.ssh/id_ed25519_workspace

